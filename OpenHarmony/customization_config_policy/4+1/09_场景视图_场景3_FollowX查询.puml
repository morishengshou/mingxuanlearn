@startuml 09_场景视图_场景3_FollowX查询
!theme plain
skinparam backgroundColor #FEFEFE
skinparam defaultFontName "Microsoft YaHei"
skinparam sequenceMessageAlign center
skinparam NoteBackgroundColor #FFFDE7

title 场景3 — Follow-X 运营商路径查询（UC6）\nGetOneCfgFileEx 与 SIM 运营商子目录

participant "业务应用程序"                  as APP    #EAF4FB
participant "libconfig_policy_util.so"      as LIB    #D5E8D4
participant "config_policy_param_adapter.h" as ADAPT  #FFF2CC
participant "tmpfs params"                  as TMPFS  #D5E8D4
participant "文件系统"                       as FS     #F5F5F5

note over APP
  Follow-X 机制：
  在标准层路径中插入运营商子目录
  路径变为：<layer>/etc/carrier/<opkey>/<relPath>
  支持模式：
    NO_RULE_FOLLOWED (1) — 不走运营商子目录
    SIM_DEFAULT (10)     — 自动读取 opkey0
    SIM_1 (11)           — 强制读取 opkey0
    SIM_2 (12)           — 强制读取 opkey1
    USER_DEFINED (100)   — 使用 extra 参数
end note

== 场景3a：SIM_1 模式（读取 SIM卡1 运营商配置） ==

APP   ->  LIB   : GetOneCfgFileEx("etc/OpkeyInfo.json",\n  buf, MAX_PATH_LEN,\n  FOLLOWX_MODE_SIM_1, "")
activate LIB

  LIB  ->  ADAPT : SystemGetParameter("telephony.sim.opkey0", NULL, &len)
  ADAPT -> TMPFS : fopen + scan + fclose
  TMPFS --> ADAPT : "46060"
  ADAPT --> LIB  : len=6

  LIB  ->  ADAPT : SystemGetParameter("telephony.sim.opkey0", buf, &len)
  ADAPT -> TMPFS : fopen + scan + fclose
  ADAPT --> LIB  : opkey="46060"

  LIB  ->  LIB   : 构造 Follow-X 路径:\n"/oem/etc/carrier/46060/etc/OpkeyInfo.json"

  note over LIB
    按优先级从高到低逐层检查
    同时尝试运营商子目录路径
  end note

  LIB  ->  FS    : access("/oem/etc/carrier/46060/etc/OpkeyInfo.json", F_OK)
  FS   --> LIB   : 0 (命中!)

LIB   --> APP   : "/oem/etc/carrier/46060/etc/OpkeyInfo.json"
deactivate LIB

== 场景3b：USER_DEFINED 模式（自定义运营商子目录） ==

APP   ->  LIB   : GetOneCfgFileEx("etc/config.xml",\n  buf, MAX_PATH_LEN,\n  FOLLOWX_MODE_USER_DEFINED, "myop/001")
activate LIB

  note over LIB
    不读取系统参数
    直接使用 extra="myop/001" 作为子目录
  end note

  LIB  ->  LIB   : 构造路径:\n"/vendor/etc/carrier/myop/001/etc/config.xml"

  LIB  ->  FS    : access("/oem/etc/carrier/myop/001/etc/config.xml", F_OK)
  FS   --> LIB   : -1 (不存在)

  LIB  ->  FS    : access("/vendor/etc/carrier/myop/001/etc/config.xml", F_OK)
  FS   --> LIB   : 0 (命中!)

LIB   --> APP   : "/vendor/etc/carrier/myop/001/etc/config.xml"
deactivate LIB

== 场景3c：NO_RULE_FOLLOWED 模式（忽略运营商，直接按层搜索） ==

APP   ->  LIB   : GetOneCfgFileEx("etc/config.xml",\n  buf, MAX_PATH_LEN,\n  FOLLOWX_MODE_NO_RULE_FOLLOWED, "")
activate LIB

  note over LIB
    不读取任何参数
    直接在各层标准路径查找
  end note

  LIB  ->  FS    : access("/oem/etc/config.xml", F_OK)
  FS   --> LIB   : -1

  LIB  ->  FS    : access("/vendor/etc/config.xml", F_OK)
  FS   --> LIB   : 0 (命中!)

LIB   --> APP   : "/vendor/etc/config.xml"
deactivate LIB

@enduml
