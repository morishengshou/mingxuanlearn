## 6. 修改 `write`

```python
def write(self, vals):
    if not self.env.context.get("safe_external_json"):
        return super().write(vals)

    clean_vals, unknown_vals, ignored_known_vals, invalid_vals = (
        self._sanitize_external_json_vals(vals)
    )

    self._log_external_json_issues(
        operation="write",
        raw_vals=vals,
        unknown_vals=unknown_vals,
        ignored_known_vals=ignored_known_vals,
        invalid_vals=invalid_vals,
    )

    if not clean_vals:
        return True

    return super().write(clean_vals)
