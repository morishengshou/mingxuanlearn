# -*- coding: utf-8 -*-
import json
import logging
from datetime import date, datetime, time

import pytz
from dateutil import parser as dateutil_parser

from odoo import api, fields, models, _
from odoo.exceptions import ValidationError

_logger = logging.getLogger(__name__)


def safe_json_dumps(value, max_length=20000):
    text = json.dumps(value, ensure_ascii=False, default=str, indent=2)
    if len(text) > max_length:
        return text[:max_length] + "\n... truncated ..."
    return text


class ExternalData(models.Model):
    _inherit = "x.external.data"  # 改成你的模型名

    @api.model
    def _is_empty_external_time_value(self, value):
        return value is False or value is None or (
            isinstance(value, str) and not value.strip()
        )

    @api.model
    def _get_external_source_tz(self):
        """
        外部 API 未携带时区信息时，默认认为它是什么时区。

        推荐调用 write/create 时显式传：
            with_context(external_source_tz="Asia/Shanghai")

        如果你的外部 API 无时区时间本身就是 UTC，则使用默认 UTC 即可。
        """
        tz_name = self.env.context.get("external_source_tz") or "UTC"

        try:
            return pytz.timezone(tz_name)
        except pytz.UnknownTimeZoneError:
            raise ValidationError(_("Invalid external_source_tz: %s") % tz_name)

    @api.model
    def _parse_external_datetime(self, value, field_name):
        """
        将外部传入的 datetime 值解析为 Python datetime。

        支持：
        - datetime 对象
        - date 对象，按当天 00:00:00 处理
        - Odoo 服务端格式：YYYY-MM-DD HH:MM:SS
        - ISO8601：2026-06-05T12:30:00+08:00 / 2026-06-05T04:30:00Z
        """
        if self._is_empty_external_time_value(value):
            return False

        if isinstance(value, datetime):
            return value

        if isinstance(value, date):
            return datetime.combine(value, time.min)

        if isinstance(value, str):
            text = value.strip()

            # 优先解析 ISO8601，包括 Z、+08:00 等时区信息
            try:
                return dateutil_parser.isoparse(text)
            except Exception:
                pass

            # 回退到 Odoo 的 Datetime 解析
            try:
                return fields.Datetime.to_datetime(text)
            except Exception as exc:
                raise ValidationError(
                    _("Invalid datetime value for field '%(field)s': %(value)s")
                    % {
                        "field": field_name,
                        "value": value,
                    }
                ) from exc

        raise ValidationError(
            _("Unsupported datetime value type for field '%(field)s': %(type)s")
            % {
                "field": field_name,
                "type": type(value).__name__,
            }
        )

    @api.model
    def _localize_external_naive_datetime(self, dt_value, field_name):
        """
        对无时区 datetime 添加外部 API 来源时区。

        默认策略：
        - 正常情况：按 external_source_tz 本地化
        - 夏令时不存在时间 / 歧义时间：默认抛错并记录日志

        如果你确实要处理 DST 歧义，可通过 context 指定：
            external_datetime_dst_strategy="standard"
        或：
            external_datetime_dst_strategy="dst"
        """
        source_tz = self._get_external_source_tz()

        try:
            return source_tz.localize(dt_value, is_dst=None)

        except pytz.AmbiguousTimeError as exc:
            strategy = self.env.context.get("external_datetime_dst_strategy", "raise")

            if strategy == "standard":
                return source_tz.localize(dt_value, is_dst=False)

            if strategy == "dst":
                return source_tz.localize(dt_value, is_dst=True)

            raise ValidationError(
                _(
                    "Ambiguous datetime value for field '%(field)s' "
                    "in timezone '%(tz)s': %(value)s"
                )
                % {
                    "field": field_name,
                    "tz": source_tz.zone,
                    "value": dt_value,
                }
            ) from exc

        except pytz.NonExistentTimeError as exc:
            raise ValidationError(
                _(
                    "Non-existent datetime value for field '%(field)s' "
                    "in timezone '%(tz)s': %(value)s"
                )
                % {
                    "field": field_name,
                    "tz": source_tz.zone,
                    "value": dt_value,
                }
            ) from exc

    @api.model
    def _external_datetime_to_utc_orm_string(self, value, field_name):
        """
        将外部 datetime 值转换为 Odoo ORM 推荐的 UTC 字符串格式：
            YYYY-MM-DD HH:MM:SS

        注意：
        - 如果 value 自带时区，直接按自带时区转 UTC。
        - 如果 value 没有时区，按 context['external_source_tz'] 解释。
        """
        dt_value = self._parse_external_datetime(value, field_name)

        if not dt_value:
            return False

        if dt_value.tzinfo is None or dt_value.utcoffset() is None:
            aware_dt = self._localize_external_naive_datetime(dt_value, field_name)
        else:
            aware_dt = dt_value

        utc_naive_dt = aware_dt.astimezone(pytz.UTC).replace(tzinfo=None)

        return fields.Datetime.to_string(utc_naive_dt)

    @api.model
    def _external_date_to_orm_string(self, value, field_name):
        """
        Date 字段不做 UTC 转换，只归一化为 YYYY-MM-DD。
        """
        if self._is_empty_external_time_value(value):
            return False

        if isinstance(value, datetime):
            return fields.Date.to_string(value.date())

        if isinstance(value, date):
            return fields.Date.to_string(value)

        if isinstance(value, str):
            text = value.strip()

            try:
                parsed_date = fields.Date.to_date(text)
                if parsed_date:
                    return fields.Date.to_string(parsed_date)
            except Exception:
                pass

            try:
                parsed_dt = dateutil_parser.isoparse(text)
                return fields.Date.to_string(parsed_dt.date())
            except Exception as exc:
                raise ValidationError(
                    _("Invalid date value for field '%(field)s': %(value)s")
                    % {
                        "field": field_name,
                        "value": value,
                    }
                ) from exc

        raise ValidationError(
            _("Unsupported date value type for field '%(field)s': %(type)s")
            % {
                "field": field_name,
                "type": type(value).__name__,
            }
        )

    @api.model
    def _normalize_external_json_field_value(self, field_name, value):
        """
        针对外部 JSON 的单个字段值做归一化。
        """
        field = self._fields.get(field_name)

        if not field:
            return value

        # Datetime 字段：自动转 UTC
        if field.type == "datetime":
            if self.env.context.get("external_datetime_to_utc", True):
                return self._external_datetime_to_utc_orm_string(value, field_name)
            return value

        # Date 字段：只做日期格式归一化，不做 UTC 转换
        if field.type == "date":
            return self._external_date_to_orm_string(value, field_name)

        return value
```

