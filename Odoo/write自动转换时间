## 5. 修改日志方法

```python
def _log_external_json_issues(
    self,
    operation,
    raw_vals,
    unknown_vals,
    ignored_known_vals,
    invalid_vals=None,
):
    invalid_vals = invalid_vals or {}

    if not unknown_vals and not ignored_known_vals and not invalid_vals:
        return

    unknown_keys = sorted(unknown_vals.keys())
    ignored_known_keys = sorted(ignored_known_vals.keys())
    invalid_keys = sorted(invalid_vals.keys())

    _logger.warning(
        "External JSON sanitized: model=%s, ids=%s, operation=%s, "
        "unknown_keys=%s, ignored_known_keys=%s, invalid_keys=%s",
        self._name,
        self.ids,
        operation,
        unknown_keys,
        ignored_known_keys,
        invalid_keys,
    )

    try:
        Log = self.env["external.payload.issue.log"].sudo()

        log_vals = {
            "model_name": self._name,
            "res_ids": ",".join(map(str, self.ids)) if self.ids else False,
            "operation": operation,
            "unknown_keys": ", ".join(unknown_keys),
            "ignored_known_keys": ", ".join(ignored_known_keys),
            "unknown_payload": safe_json_dumps(unknown_vals),
            "ignored_known_payload": safe_json_dumps(ignored_known_vals),
            "raw_payload": safe_json_dumps(raw_vals),
        }

        # 如果你已经给日志模型加了 invalid 字段，则写入
        if "invalid_keys" in Log._fields:
            log_vals["invalid_keys"] = ", ".join(invalid_keys)

        if "invalid_payload" in Log._fields:
            log_vals["invalid_payload"] = safe_json_dumps(invalid_vals)

        Log.create(log_vals)

    except Exception:
        _logger.exception("Failed to create external payload issue log.")
